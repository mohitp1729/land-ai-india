<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Land AI India (MVP)</title>

  <!-- OpenLayers + ol-mapbox-style (for OpenFreeMap styles) -->
  <link rel="stylesheet" href="https://unpkg.com/ol@v10.6.0/ol.css" />
  <script src="https://unpkg.com/ol@v10.6.0/dist/ol.js"></script>
  <script src="https://unpkg.com/ol-mapbox-style@12.5.0/dist/olms.js"></script>

  <link rel="stylesheet" href="./styles.css" />
</head>

<body>
  <div id="app">
    <aside id="sidebar">
      <h1>Land AI (India) — MVP</h1>

      <p class="hint">
        1) Click <b>Pick land</b> then click the map.<br/>
        2) Optional: <b>Pick office</b> then click the map.<br/>
        3) Choose intent + enter rates + Analyze.
      </p>

      <div class="row">
        <button id="pickLandBtn" class="primary">Pick land</button>
        <button id="pickOfficeBtn">Pick office</button>
      </div>

      <div class="grid2">
        <label>Land lat</label><input id="landLat" type="number" step="0.000001" placeholder="e.g., 19.0760" />
        <label>Land lon</label><input id="landLon" type="number" step="0.000001" placeholder="e.g., 72.8777" />
      </div>

      <div class="grid2">
        <label>Office lat</label><input id="officeLat" type="number" step="0.000001" placeholder="optional" />
        <label>Office lon</label><input id="officeLon" type="number" step="0.000001" placeholder="optional" />
      </div>

      <div class="grid2">
        <label>Radius (km)</label><input id="radiusKm" type="number" step="0.5" value="3" />
        <label>Intent</label>
        <select id="intent">
          <option value="residential">Residential / Peace</option>
          <option value="farming">Farming / Soil</option>
          <option value="commercial">Commercial</option>
          <option value="investment">Investment</option>
        </select>
      </div>

      <div class="grid2">
        <label>Market rate (₹/acre)</label><input id="marketRate" type="number" step="1000" placeholder="optional" />
        <label>Guideline value (₹/acre)</label><input id="guidelineRate" type="number" step="1000" placeholder="optional" />
      </div>

      <label class="checkbox">
        <input id="bhuvanToggle" type="checkbox" />
        Show Bhuvan LULC overlay (example layer)
      </label>

      <button id="analyzeBtn" class="primary big">Analyze</button>

      <div id="status" class="status"></div>
      <pre id="output" class="output">{}</pre>

      <p class="fineprint">
        Map base: OpenFreeMap / OpenMapTiles / OpenStreetMap.  
        Overlay: Bhuvan (NRSC).  
        This MVP is informational, not legal/financial advice.
      </p>
    </aside>

    <main id="map"></main>
  </div>

  <script src="./app.js"></script>
</body>
</html>
